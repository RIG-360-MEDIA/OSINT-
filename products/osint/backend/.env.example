# Copy to .env and fill in. Never commit .env.
# For LOCAL dev via SSH tunnel: postgresql+asyncpg://analytics_user:PASS@localhost:5433/rig
# For Hetzner Docker network: postgresql+asyncpg://analytics_user:PASS@rig-postgres:5432/rig
OSINT_DB_URL=postgresql+asyncpg://analytics_user:CHANGEME@localhost:5433/rig

# CORS allow-list (comma-separated). Production brief frontend domain belongs here.
OSINT_CORS_ORIGINS=http://localhost:3001,http://localhost:5173,https://brief.rig360media.com

# Pool sizing — keep small; service is read-only and lightly trafficked
OSINT_DB_POOL_SIZE=5
OSINT_DB_MAX_OVERFLOW=10

# Bind address + port for uvicorn (Docker exposes this)
OSINT_HOST=0.0.0.0
OSINT_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
OSINT_LOG_LEVEL=INFO

# ── LLM pool (groq_client.py) ──────────────────────────────────────────────
# Multi-key Groq + Cerebras pool with rotation + automatic Groq→Cerebras
# failover. Comma-separated keys; the same pool rig-backend uses. In the
# Hetzner deploy these come from infra/.env (copied from .env.prod) and are
# injected via docker-compose; NEVER bake them into the image or commit them.
# If unset, llm_synth degrades gracefully and brief prose falls back to the
# deterministic template — the service still boots.
GROQ_API_KEYS=
CEREBRAS_API_KEYS=
# Force the local Ollama lane off for this service (it has no local GPU).
LOCAL_LLM_ENABLED=0
