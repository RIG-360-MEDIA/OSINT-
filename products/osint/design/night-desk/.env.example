# ── ROBIN-OSINT — environment template ──────────────────────────────────────
# Copy to .env (gitignored) and fill values. NEVER commit real keys.
#
# RULE: client-exposed vars MUST be prefixed VITE_ — they are bundled into the
# browser and are PUBLIC. Put ONLY public/publishable values behind VITE_.
# Every secret API key is read by the server proxy (server/proxy.mjs) and never
# reaches the client. This keeps ROBIN-OSINT independent of World Monitor: our
# own keys, our own proxy, no WM code or services at runtime.

# ── client (public, bundled into browser) ───────────────────────────────────
# Basemap style URL. Empty → defaults to Carto dark-matter (free, no key, and
# NOT World Monitor). For full independence, self-host Protomaps/OpenFreeMap/
# Versatiles and point this at your own style.json.
VITE_BASEMAP_URL=
# Where the client reaches the proxy in dev (Vite also proxies /api → here).
VITE_PROXY_URL=http://localhost:8788

# ── server proxy (SECRET — never prefix these VITE_) ─────────────────────────
PROXY_PORT=8788
PROXY_ALLOW_ORIGIN=http://localhost:5180

# Data-source keys — reused from OUR OWN accounts. Values live only in .env
# (gitignored). Re-fetchable from each provider dashboard, so deleting World
# Monitor never locks us out.
NASA_FIRMS_API_KEY=
OPENAQ_API_KEY=
CLOUDFLARE_API_TOKEN=
AISSTREAM_API_KEY=
UCDP_ACCESS_TOKEN=
ACLED_ACCESS_TOKEN=
RELIEFWEB_APPNAME=robin-osint

# LLM (optional, for AI features) — server-side only
GROQ_API_KEY=
OPENROUTER_API_KEY=
LLM_API_URL=

# Keyless sources need NO key (called direct or via proxy for CORS):
#   GDELT · World Bank · USGS quakes · geoBoundaries · Open-Meteo
