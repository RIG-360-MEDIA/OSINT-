# ============================================================
# RIG SURVEILLANCE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Database
POSTGRES_PASSWORD=changeme

# Groq — comma-separated list of API keys
# Get free keys at console.groq.com
GROQ_API_KEYS=gsk_key1,gsk_key2

# Supabase — create project at supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NewsData.io — optional, leave empty to skip
# Get free key at newsdata.io
NEWSDATA_API_KEY=

# FreshRSS — filled in P03
FRESHRSS_URL=http://rig-backend:8080
FRESHRSS_USERNAME=admin
FRESHRSS_PASSWORD=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Environment
ENVIRONMENT=development

# NLP Settings
NLP_BATCH_SIZE=25
BRIEF_ARTICLE_LIMIT=30

# ============================================================
# World Monitor pillar (iframe-embedded at /worldmonitor)
# All keys optional — WM degrades gracefully if any are unset.
# Get keys from each provider; leave blank to disable that data source.
# ============================================================

# Internal token for the local Redis-REST shim (any string is fine).
WM_REDIS_TOKEN=wm-local-token

# Override only if running rig-frontend on the host (npm run dev).
# Inside Docker the default http://rig-worldmonitor:8080 works.
# WM_INTERNAL_URL=http://localhost:3001

# LLM (any OpenAI-compatible endpoint). Falls back to GROQ if unset.
WM_LLM_API_URL=
WM_LLM_API_KEY=
WM_LLM_MODEL=
WM_GROQ_API_KEY=

# Data sources
AISSTREAM_API_KEY=
FINNHUB_API_KEY=
EIA_API_KEY=
FRED_API_KEY=
ACLED_ACCESS_TOKEN=
NASA_FIRMS_API_KEY=
CLOUDFLARE_API_TOKEN=
AVIATIONSTACK_API=
