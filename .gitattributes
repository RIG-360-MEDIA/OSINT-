# Normalize line endings so Windows checkouts never produce phantom whole-file
# diffs against the Linux server again. Code is always LF in the repo.
* text=auto eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.sql  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
# Windows-only scripts stay CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
# Binaries: never touch
*.png  binary
*.jpg  binary
*.pdf  binary
*.ico  binary
